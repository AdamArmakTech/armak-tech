<section class="armak-about" id="about">
  <canvas id="aboutParticles"></canvas>
  <div class="armak-about-grid">

    <!-- Left column: title only -->
    <div class="armak-about-left armak-reveal">
      <div class="armak-section-eyebrow">Why Armak?</div>
      <h2>Our Strategic <span class="accent">Vision</span></h2>
    </div>

    <!-- Right column: stacked card deck -->
    <div class="armak-about-right">
      <div class="about-deck-wrap armak-reveal" style="--delay:0.15s;">
        <div class="about-deck" id="aboutDeck">
          <article class="deck-card" data-pos="0">
            <div class="deck-card-tag">01 — Legacy</div>
            <h3 class="deck-card-title">Since 1998</h3>
            <p class="deck-card-body">Since 1998, Armak Technologies has been the infrastructure partner organizations rely on when failure isn't an option. We design and deploy high-performance, low-voltage, and enterprise networking systems — the backbone of operational efficiency.</p>
            <div class="deck-card-footer">
              <span class="deck-card-meta">01 / 03</span>
              <span class="deck-card-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </article>
          <article class="deck-card" data-pos="1">
            <div class="deck-card-tag">02 — Our Standard</div>
            <h3 class="deck-card-title">Global-Grade Excellence</h3>
            <p class="deck-card-body">Our standard is clear: global-grade technical excellence for every client. We don't just solve technical hurdles — we engineer for maximum reliability and long-term asset value.</p>
            <div class="deck-card-footer">
              <span class="deck-card-meta">02 / 03</span>
              <span class="deck-card-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </article>
          <article class="deck-card" data-pos="2">
            <div class="deck-card-tag">03 — Intelligence &amp; Innovation</div>
            <h3 class="deck-card-title">Two Decades In. Zero Shortcuts.</h3>
            <p class="deck-card-body">From structured cabling to enterprise security, we provide the foundational systems that keep businesses competitive. Two decades in. Zero shortcuts.</p>
            <div class="deck-card-footer">
              <span class="deck-card-meta">03 / 03</span>
              <span class="deck-card-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </article>
        </div>
      </div>
    </div><!-- end armak-about-right -->

  </div><!-- end armak-about-grid -->

