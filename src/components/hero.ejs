<section class="armak-hero" id="home">
  <div class="armak-hero-bg" id="heroParallaxBg"></div>
  <canvas id="heroParticles"></canvas>
  <div class="armak-hero-grid">
    <div>
      <div class="armak-eyebrow armak-reveal" style="--delay: 0.1s;">Trusted Since 1998 · Serving All of Southern California</div>
      <h1 class="armak-reveal" style="--delay: 0.2s;">Engineered<span class="accent">to Last.</span></h1>
      <p class="lead armak-reveal" style="--delay: 0.4s;">25 years building the infrastructure Southern California's most demanding facilities run on — from first conduit to final certification. Built for today. Engineered for what's next.</p>
      <div class="armak-ctas armak-reveal" style="--delay: 0.55s;">
        <a href="#contact" class="armak-btn armak-btn-primary">Request a Site Assessment
          <svg class="arrow" viewBox="0 0 18 12" fill="none"><path d="M1 6h16m0 0L12 1m5 5l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
        </a>
        <a href="#services" class="armak-btn armak-btn-outline">View Services</a>
      </div>
    </div>
    <div class="armak-hero-visual armak-reveal" style="--delay: 0.7s;">
      <div class="armak-hero-map" id="heroMap">
        <svg class="map-svg" viewBox="200 100 720 660" preserveAspectRatio="xMidYMid meet" overflow="visible" style="overflow: visible;" xmlns="http://www.w3.org/2000/svg" aria-label="Southern California service area">
          <defs>
            <pattern id="topoGrid" width="44" height="44" patternUnits="userSpaceOnUse">
              <path d="M 44 0 L 0 0 0 44" fill="none" stroke="rgba(0,180,255,0.12)" stroke-width="0.5"/>
            </pattern>
            <pattern id="topoGridMajor" width="220" height="220" patternUnits="userSpaceOnUse">
              <path d="M 220 0 L 0 0 0 220" fill="none" stroke="rgba(0,200,255,0.20)" stroke-width="0.7"/>
            </pattern>
            <radialGradient id="hqGlow" cx="0.5" cy="0.5">
              <stop offset="0%" stop-color="rgba(220,20,60,0.7)"/>
              <stop offset="55%" stop-color="rgba(220,20,60,0.18)"/>
              <stop offset="100%" stop-color="rgba(220,20,60,0)"/>
            </radialGradient>
            <linearGradient id="radarGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(220,20,60,0.95)"/>
              <stop offset="100%" stop-color="rgba(220,20,60,0)"/>
            </linearGradient>
            <linearGradient id="landGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="rgba(0,90,180,0.10)"/>
              <stop offset="100%" stop-color="rgba(0,60,140,0.18)"/>
            </linearGradient>
          </defs>

          <!-- Topo radar grid — transparent, blends with page -->
          <rect x="200" y="100" width="720" height="660" fill="url(#topoGrid)"/>
          <rect x="200" y="100" width="720" height="660" fill="url(#topoGridMajor)"/>

          <g>
            <!-- LAND MASS — fill only, no border (only coast path is stroked separately) -->
            <path d="M 20.3,151.4 L 167.9,191.7 L 247.7,203.6 L 346.8,227.5 L 361.3,248.3 L 363.8,284.0 L 462.9,316.7 L 537.9,322.7 L 557.3,346.4 L 563.3,376.0 L 588.7,411.6 L 612.9,396.8 L 658.8,429.3 L 687.9,444.1 L 726.6,482.5 L 760.4,512.0 L 808.8,565.0 L 835.4,623.7 L 837.8,670.6 L 859.6,705.7 L 869.3,752.5 L 876.5,759.8 L 1070.0,759.8 L 1070.0,75.0 L 30.0,75.0 L 20.3,151.4 Z"
              fill="url(#landGrad)" stroke="none"/>

            <!-- Animated coastline (just the outline highlight) -->
            <path class="map-coast" d="M 20.3,151.4 L 167.9,191.7 L 247.7,203.6 L 346.8,227.5 L 361.3,248.3 L 363.8,284.0 L 462.9,316.7 L 537.9,322.7 L 557.3,346.4 L 563.3,376.0 L 588.7,411.6 L 612.9,396.8 L 658.8,429.3 L 687.9,444.1 L 726.6,482.5 L 760.4,512.0 L 808.8,565.0 L 835.4,623.7 L 837.8,670.6 L 859.6,705.7 L 869.3,752.5 L 876.5,759.8"
              fill="none" stroke="rgba(0,180,255,0.85)" stroke-width="1.8" stroke-dasharray="4 5"/>

            <!-- Inland mountain ranges — Transverse + San Bernardinos -->
            <path d="M 470,200 Q 560,210 650,225 Q 720,240 790,255" fill="none" stroke="rgba(0,140,255,0.32)" stroke-width="1.4" stroke-dasharray="3 7"/>
            <path d="M 720,255 Q 800,275 870,295" fill="none" stroke="rgba(0,140,255,0.28)" stroke-width="1.2" stroke-dasharray="3 7"/>

            <!-- (border line removed — no straight bordering lines) -->

            <!-- Lat/Lon graticule labels — gives map context -->
            <g font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(0,180,255,0.5)" letter-spacing="0.05em">
              <text x="220" y="115">34.85°N</text>
              <text x="220" y="755">32.53°N</text>
              <text x="850" y="115" text-anchor="end">119°W</text>
              <text x="900" y="755" text-anchor="end">117°W</text>
            </g>

            <!-- Radar concentric range rings around HQ (Glendale 597.2, 286.4) -->
            <g class="radar-rings" fill="none" stroke="rgba(220,20,60,0.22)" stroke-width="1" stroke-dasharray="2 4">
              <circle cx="597.2" cy="286.4" r="80"/>
              <circle cx="597.2" cy="286.4" r="160"/>
              <circle cx="597.2" cy="286.4" r="260"/>
              <circle cx="597.2" cy="286.4" r="380"/>
            </g>
            <!-- Radar crosshair guides through HQ -->
