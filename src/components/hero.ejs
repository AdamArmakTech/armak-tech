              <g class="map-city" data-city="Lancaster"><circle class="pulse-ring" cx="625.7" cy="123.8" r="5"/><circle class="pulse-ring d2" cx="625.7" cy="123.8" r="5"/><circle class="city-dot" cx="625.7" cy="123.8" r="3.5"/><text class="city-label" x="635.7" y="127.8">LANCASTER</text></g>
              <g class="map-city" data-city="Palmdale"><circle class="pulse-ring" cx="630.8" cy="156.1" r="5"/><circle class="pulse-ring d2" cx="630.8" cy="156.1" r="5"/><circle class="city-dot" cx="630.8" cy="156.1" r="3.5"/><text class="city-label" x="640.8" y="160.1">PALMDALE</text></g>
              <g class="map-city" data-city="Santa Clarita"><circle class="pulse-ring" cx="527.7" cy="212.3" r="5"/><circle class="pulse-ring d2" cx="527.7" cy="212.3" r="5"/><circle class="city-dot" cx="527.7" cy="212.3" r="3.5"/><text class="city-label end" x="517.7" y="208.3">SANTA CLARITA</text></g>
              <g class="map-city" data-city="Burbank"><circle class="pulse-ring" cx="584.3" cy="275.1" r="5"/><circle class="pulse-ring d2" cx="584.3" cy="275.1" r="5"/><circle class="city-dot" cx="584.3" cy="275.1" r="3.5"/><text class="city-label end" x="574.3" y="267.1">BURBANK</text></g>
              <g class="map-city is-hq" data-city="Glendale (HQ)"><circle class="hq-ring-outer" cx="597.2" cy="286.4" r="28"/><circle class="hq-ring-inner" cx="597.2" cy="286.4" r="16"/><circle class="city-dot hq" cx="597.2" cy="286.4" r="6"/><text class="city-label hq" x="597.2" y="248" text-anchor="middle">GLENDALE · HQ</text></g>
              <g class="map-city" data-city="Pasadena"><circle class="pulse-ring" cx="650.0" cy="283.0" r="5"/><circle class="pulse-ring d2" cx="650.0" cy="283.0" r="5"/><circle class="city-dot" cx="650.0" cy="283.0" r="3.5"/><text class="city-label" x="660.0" y="279.0">PASADENA</text></g>
              <g class="map-city" data-city="Beverly Hills"><circle class="pulse-ring" cx="562.1" cy="306.9" r="5"/><circle class="pulse-ring d2" cx="562.1" cy="306.9" r="5"/><circle class="city-dot" cx="562.1" cy="306.9" r="3.5"/><text class="city-label end" x="552.1" y="310.9">BEVERLY HILLS</text></g>
              <g class="map-city" data-city="Malibu"><circle class="pulse-ring" cx="470.2" cy="320.9" r="5"/><circle class="pulse-ring d2" cx="470.2" cy="320.9" r="5"/><circle class="city-dot" cx="470.2" cy="320.9" r="3.5"/><text class="city-label end" x="460.2" y="324.9">MALIBU</text></g>
              <g class="map-city" data-city="Los Angeles"><circle class="pulse-ring" cx="599.8" cy="313.2" r="5"/><circle class="pulse-ring d2" cx="599.8" cy="313.2" r="5"/><circle class="city-dot" cx="599.8" cy="313.2" r="4.5"/><text class="city-label" x="613.8" y="331.2">LOS ANGELES</text></g>
              <g class="map-city" data-city="Long Beach"><circle class="pulse-ring" cx="612.2" cy="396.8" r="5"/><circle class="pulse-ring d2" cx="612.2" cy="396.8" r="5"/><circle class="city-dot" cx="612.2" cy="396.8" r="4.5"/><text class="city-label end" x="602.2" y="400.8">LONG BEACH</text></g>
              <g class="map-city" data-city="Anaheim"><circle class="pulse-ring" cx="679.6" cy="377.2" r="5"/><circle class="pulse-ring d2" cx="679.6" cy="377.2" r="5"/><circle class="city-dot" cx="679.6" cy="377.2" r="3.5"/><text class="city-label" x="689.6" y="387.2">ANAHEIM</text></g>
              <g class="map-city" data-city="Huntington Beach"><circle class="pulse-ring" cx="659.1" cy="429.6" r="5"/><circle class="pulse-ring d2" cx="659.1" cy="429.6" r="5"/><circle class="city-dot" cx="659.1" cy="429.6" r="3.5"/><text class="city-label end" x="649.1" y="433.6">HUNTINGTON BEACH</text></g>
              <g class="map-city" data-city="Santa Ana"><circle class="pulse-ring" cx="691.0" cy="404.2" r="5"/><circle class="pulse-ring d2" cx="691.0" cy="404.2" r="5"/><circle class="city-dot" cx="691.0" cy="404.2" r="3.5"/><text class="city-label" x="701.0" y="408.2">SANTA ANA</text></g>
              <g class="map-city" data-city="Irvine"><circle class="pulse-ring" cx="700.9" cy="421.9" r="5"/><circle class="pulse-ring d2" cx="700.9" cy="421.9" r="5"/><circle class="city-dot" cx="700.9" cy="421.9" r="3.5"/><text class="city-label" x="710.9" y="437.9">IRVINE</text></g>
              <g class="map-city" data-city="San Bernardino"><circle class="pulse-ring" cx="830.6" cy="296.5" r="5"/><circle class="pulse-ring d2" cx="830.6" cy="296.5" r="5"/><circle class="city-dot" cx="830.6" cy="296.5" r="3.5"/><text class="city-label" x="840.6" y="300.5">SAN BERNARDINO</text></g>
              <g class="map-city" data-city="Riverside"><circle class="pulse-ring" cx="804.9" cy="342.5" r="5"/><circle class="pulse-ring d2" cx="804.9" cy="342.5" r="5"/><circle class="city-dot" cx="804.9" cy="342.5" r="3.5"/><text class="city-label" x="814.9" y="336.5">RIVERSIDE</text></g>
              <g class="map-city" data-city="Temecula"><circle class="pulse-ring" cx="864.9" cy="478.3" r="5"/><circle class="pulse-ring d2" cx="864.9" cy="478.3" r="5"/><circle class="city-dot" cx="864.9" cy="478.3" r="3.5"/><text class="city-label" x="874.9" y="482.3">TEMECULA</text></g>
              <g class="map-city" data-city="Oceanside"><circle class="pulse-ring" cx="809.0" cy="566.1" r="5"/><circle class="pulse-ring d2" cx="809.0" cy="566.1" r="5"/><circle class="city-dot" cx="809.0" cy="566.1" r="3.5"/><text class="city-label end" x="799.0" y="570.1">OCEANSIDE</text></g>
              <g class="map-city" data-city="Escondido"><circle class="pulse-ring" cx="879.9" cy="588.8" r="5"/><circle class="pulse-ring d2" cx="879.9" cy="588.8" r="5"/><circle class="city-dot" cx="879.9" cy="588.8" r="3.5"/><text class="city-label" x="889.9" y="592.8">ESCONDIDO</text></g>
              <g class="map-city" data-city="San Diego"><circle class="pulse-ring" cx="861.8" cy="707.2" r="5"/><circle class="pulse-ring d2" cx="861.8" cy="707.2" r="5"/><circle class="city-dot" cx="861.8" cy="707.2" r="4.5"/><text class="city-label end" x="851.8" y="701.2">SAN DIEGO</text></g>
              <g class="map-city" data-city="Chula Vista"><circle class="pulse-ring" cx="880.4" cy="729.1" r="5"/><circle class="pulse-ring d2" cx="880.4" cy="729.1" r="5"/><circle class="city-dot" cx="880.4" cy="729.1" r="3.5"/><text class="city-label" x="890.4" y="733.1">CHULA VISTA</text></g>
            </g>
          </g>

          <!-- HUD frame removed -->

          <!-- HUD readouts -->
          <g font-family="JetBrains Mono, monospace" font-size="11" letter-spacing="0.15em" fill="rgba(0,180,255,0.7)">
            <text x="220" y="125">SECTOR · SOCAL</text>
            <text x="220" y="142" font-size="9" fill="rgba(0,180,255,0.45)">SCOPE: 33°N — 35°N · 120°W — 117°W</text>
            <text x="900" y="125" text-anchor="end" fill="rgba(220,20,60,0.85)">● LIVE</text>
            <text x="900" y="142" text-anchor="end" font-size="9" fill="rgba(0,180,255,0.45)">RNG: 380KM</text>
          </g>

          <!-- Signal layer (JS-driven traces between HQ and cities) -->
          <g class="map-signals" id="mapSignals"></g>
        </svg>
      </div>
      <img src="/armak-logo-color.png" alt="Armak Technologies" style="width:100%;max-width:560px;height:auto;margin-top:32px;display:block;" />
    </div>
  </div>
  <!-- Logo seal at hero bottom -->
  <a href="#" class="armak-hero-seal" aria-label="Armak Technologies">
    <img src="/armak-logo.png" alt="" />
  </a>
</section>