              <line x1="597.2" y1="286.4" x2="1142" y2="286.4" stroke="rgba(220,20,60,0.95)" stroke-width="1.4"/>
            </g>

            <!-- HQ glow halo -->
            <circle cx="597.2" cy="286.4" r="65" fill="url(#hqGlow)"/>

