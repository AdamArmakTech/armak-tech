<section class="armak-stats">
  <canvas id="statsCircuit"></canvas>
  <div class="armak-stats-grid">
    <div class="armak-reveal" style="--delay: 0s;">
      <div class="armak-stat-num"><span class="armak-count" data-target="25">0</span><span class="plus">+</span></div>
      <div class="armak-stat-label">Years in Business</div>
      <div class="armak-stat-bar"><div class="armak-stat-bar-fill" data-pct="100"></div></div>
    </div>
    <div class="armak-reveal" style="--delay: 0.1s;">
      <div class="armak-stat-num"><span class="armak-count" data-target="1000" data-format="comma">0</span><span class="plus">+</span></div>
      <div class="armak-stat-label">Projects Delivered</div>
      <div class="armak-stat-bar"><div class="armak-stat-bar-fill" data-pct="100"></div></div>
    </div>
    <div class="armak-reveal" style="--delay: 0.2s;">
      <div class="armak-stat-num">24/7</div>
      <div class="armak-stat-label">Support Available</div>
      <div class="armak-stat-bar"><div class="armak-stat-bar-fill" data-pct="100"></div></div>
    </div>
    <div class="armak-reveal" style="--delay: 0.3s;">
      <div class="armak-stat-num">SoCal</div>
      <div class="armak-stat-label">Service Area</div>
      <div class="armak-stat-bar"><div class="armak-stat-bar-fill" data-pct="100"></div></div>
    </div>
  </div>
</section>