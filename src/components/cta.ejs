<section class="armak-cta" id="contact">
  <div class="armak-cta-inner">
    <div>
      <div class="armak-cta-eyebrow armak-reveal">Start Your Project</div>
      <h2 class="armak-reveal" style="--delay: 0.15s;">Let's <span class="cta-scope">Sc<svg class="cta-crosshair-o" aria-hidden="true" viewBox="0 0 52 56" fill="none" stroke="currentColor" stroke-linecap="round" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="28" r="21" stroke-width="4"/><line x1="0" y1="28" x2="8" y2="28" stroke-width="2.5"/><line x1="44" y1="28" x2="52" y2="28" stroke-width="2.5"/><line x1="26" y1="0" x2="26" y2="8" stroke-width="2.5"/><line x1="26" y1="48" x2="26" y2="56" stroke-width="2.5"/><line x1="17" y1="28" x2="20" y2="28" stroke-width="1.5"/><line x1="32" y1="28" x2="35" y2="28" stroke-width="1.5"/><line x1="26" y1="18" x2="26" y2="21" stroke-width="1.5"/><line x1="26" y1="35" x2="26" y2="38" stroke-width="1.5"/><circle cx="26" cy="28" r="2.5" fill="currentColor" stroke="none"/></svg>pe</span><br><span class="accent">Your Next <span class="cta-build-word">Build</span>.</span></h2>
      <p class="armak-reveal" style="--delay: 0.3s;">Tell us what you're building. We'll assess the site, scope the infrastructure, and give you a clear plan — no guesswork, no surprises.</p>
    </div>
    <div class="armak-cta-side armak-reveal" style="--delay: 0.4s;">
      <!-- 
        IMPORTANT: To make this form actually deliver emails, sign up at https://formspree.io (free),
        create a form, and replace YOUR_FORMSPREE_ID below with the ID they give you.
        Until then, this form will just look pretty but won't send anything.
      -->
      <form class="armak-form" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST">
        <div class="armak-form-row">
          <input type="text" name="name" placeholder="Your Name" required>
          <input type="text" name="company" placeholder="Company">
        </div>
        <div class="armak-form-row">
          <input type="email" name="email" placeholder="Email Address" required>
          <input type="tel" name="phone" placeholder="Phone">
        </div>
        <select name="project_type" required>
          <option value="">Project Type…</option>
          <option value="Structured Cabling & Fiber">Structured Cabling &amp; Fiber</option>
          <option value="Network & Firewall">Network &amp; Firewall</option>
          <option value="CCTV & Surveillance">CCTV &amp; Surveillance</option>
          <option value="Access Control">Access Control</option>
          <option value="Unified Comms / VoIP">Unified Comms / VoIP</option>
          <option value="Audio / Video">Audio / Video</option>
          <option value="Other">Other / Multiple Services</option>
        </select>
        <textarea name="message" placeholder="Tell us about your project — site location, scale, timeline." required></textarea>
        <button type="submit" class="armak-form-submit">Request My Site Assessment
          <svg class="arrow" viewBox="0 0 18 12" fill="none" width="18" height="12"><path d="M1 6h16m0 0L12 1m5 5l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
        </button>
      </form>
      <div class="armak-contact-block">
        <div class="armak-contact-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Serving All of Southern California</span>
        </div>
        <div class="armak-contact-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.46 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.37 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
          <a href="tel:+18188584615">(818) 858-4615</a>
        </div>
        <div class="armak-contact-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
          <a href="mailto:sales@armak.tech">sales@armak.tech</a>
        </div>
        <div class="armak-contact-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
          <a href="mailto:support@armak.tech">support@armak.tech</a>
        </div>
      </div>
    </div>
  </div>
</section>